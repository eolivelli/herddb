<FindBugsFilter>
    <!-- this work work on JDK11  https://github.com/spotbugs/spotbugs-maven-plugin/issues/92 -->
    <Bug pattern="RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE"/>
    <!-- Useless @SuppressWarnings: caused by RCN_REDUNDANT_NULLCHECK exclusion above making suppressions stale -->
    <Bug pattern="US_USELESS_SUPPRESSION_ON_CLASS"/>
    <Bug pattern="US_USELESS_SUPPRESSION_ON_METHOD"/>
    <Bug pattern="US_USELESS_SUPPRESSION_ON_FIELD"/>
    <!-- Pre-existing issues surfaced by spotbugs upgrade to Java 22 support; to be addressed separately -->
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    <Bug pattern="AT_NONATOMIC_OPERATIONS_ON_SHARED_VARIABLE"/>
    <Bug pattern="AT_NONATOMIC_64BIT_PRIMITIVE"/>
    <Bug pattern="AT_STALE_THREAD_WRITE_OF_PRIMITIVE"/>
    <Bug pattern="EI_EXPOSE_REP"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
    <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
    <Bug pattern="SING_SINGLETON_HAS_NONPRIVATE_CONSTRUCTOR"/>
    <!-- Pre-existing: lock not released on all paths in TableManager; requires careful refactor -->
    <Bug pattern="UL_UNRELEASED_LOCK"/>
    <!-- Pre-existing: dead local store in VectorIndexManager.loadFromStatus -->
    <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    <!-- Pre-existing: JMXUtils.getMBeanServer exposes internal MBeanServer reference -->
    <Bug pattern="MS_EXPOSE_REP"/>
    <!-- Pre-existing: catching NullPointerException in CompiledFunction -->
    <Bug pattern="DCN_NULLPOINTER_EXCEPTION"/>
    <!-- Pre-existing: boxing/unboxing to parse primitives in HerdDBCLI -->
    <Bug pattern="DM_BOXED_PRIMITIVE_FOR_PARSING"/>
    <!-- Generated protobuf classes implement Serializable via singleton pattern -->
    <Bug pattern="SING_SINGLETON_IMPLEMENTS_SERIALIZABLE"/>
    <!-- Pre-existing: negating compareTo result in CachingObjectStorage sort -->
    <Bug pattern="RV_NEGATING_RESULT_OF_COMPARETO"/>
    <!-- Pre-existing: potential null from getParent() in LocalObjectStorage -->
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    <!-- Pre-existing: ignored return values in DatasetLoader benchmark utility -->
    <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
    <!-- Pre-existing: integral division cast to double in IngestionWorker -->
    <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE"/>
    <!-- Pre-existing: broad exception catch in benchmark workers -->
    <Bug pattern="REC_CATCH_EXCEPTION"/>
    <!-- Pre-existing: System.exit() in benchmark QueryWorker -->
    <Bug pattern="DM_EXIT"/>
    <!-- Pre-existing: resource handling in benchmark QueryWorker -->
    <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    <Bug pattern="ODR_OPEN_DATABASE_RESOURCE"/>
    <!-- Benchmark tool builds SQL from trusted config values (int fields), not user input -->
    <Match>
        <Class name="herddb.vectortesting.VectorBench"/>
        <Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE"/>
    </Match>
</FindBugsFilter>
